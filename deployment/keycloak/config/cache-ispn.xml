<!--
  Infinispan configuration used by Keycloak for distributed caching.
  This file defines cluster communication, cache containers, and cache types.
-->

<infinispan
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="urn:infinispan:config:16.0 https://infinispan.org/schemas/infinispan-config-16.0.xsd"
        xmlns="urn:infinispan:config:16.0"
>

    <!--
      JGroups configuration defines how cluster nodes discover each other.
      jdbc-ping uses the database to store cluster membership information.
    -->
    <jgroups>
        <stack-file name="jdbc-ping" path="default-jgroups-jdbc-ping.xml"/>
    </jgroups>


    <!--
      Cache container used by Keycloak.
      All cache definitions are declared inside this container.
    -->
    <cache-container name="keycloak" statistics="true">

        <!--
          Transport configuration for cluster communication.
          stack: defines the JGroups stack used
          cluster: logical cluster name shared by all nodes
        -->
        <transport
                lock-timeout="60000"
                stack="jdbc-ping"
                cluster="keycloak-cluster"
        />


        <!-- ===================================================== -->
        <!-- LOCAL CACHES (not shared across nodes)                 -->
        <!-- Each node keeps its own copy of the cached data        -->
        <!-- ===================================================== -->

        <!--
          Cache persisted realm configuration data
          Example: realm settings, client configuration, roles
        -->
        <local-cache name="realms">
            <memory max-count="10000"/>
        </local-cache>

        <!--
          Cache persisted user data
          Example: username, attributes, email
        -->
        <local-cache name="users">
            <memory max-count="10000"/>
        </local-cache>

        <!--
          Cache authorization data such as policies and permissions
        -->
        <local-cache name="authorization">
            <memory max-count="10000"/>
        </local-cache>

        <!--
          Cache public keys from external identity providers
          Used for verifying JWT tokens
        -->
        <local-cache name="keys">
            <expiration lifespan="3600000"/>
        </local-cache>

        <!--
          Cache certificate revocation lists used by X509 authentication
        -->
        <local-cache name="crl">
            <expiration lifespan="3600000"/>
        </local-cache>


        <!-- ===================================================== -->
        <!-- REPLICATED CACHE                                       -->
        <!-- All nodes keep a full copy of the cache                -->
        <!-- ===================================================== -->

        <!--
          Used internally to propagate invalidation messages
          between cluster nodes when cached data changes.
        -->
        <replicated-cache name="work">
            <expiration lifespan="2m"/>
        </replicated-cache>


        <!-- ===================================================== -->
        <!-- DISTRIBUTED CACHES                                     -->
        <!-- Data is partitioned across nodes with replication      -->
        <!-- owners = number of nodes storing each entry            -->
        <!-- ===================================================== -->

        <!--
          Temporary authentication session during login flows
          Example: login page -> OTP -> redirect
        -->
        <distributed-cache name="authenticationSessions" owners="3">
            <expiration lifespan="300000"/>
        </distributed-cache>

        <!--
          Active user sessions after successful login (SSO sessions)
        -->
        <distributed-cache name="sessions" owners="3">
            <expiration lifespan="-1"/>
        </distributed-cache>

        <!--
          Client sessions associated with user sessions
          Example: SPA, mobile app, backend services
        -->
        <distributed-cache name="clientSessions" owners="3">
            <expiration lifespan="-1"/>
        </distributed-cache>

        <!--
          Offline user sessions used for long-lived refresh tokens
        -->
        <distributed-cache name="offlineSessions" owners="3">
            <expiration lifespan="-1"/>
        </distributed-cache>

        <!--
          Offline client sessions used with offline tokens
        -->
        <distributed-cache name="offlineClientSessions" owners="3">
            <expiration lifespan="-1"/>
        </distributed-cache>

        <!--
          Tracks failed login attempts for brute-force protection
          and fraud detection
        -->
        <distributed-cache name="loginFailures" owners="3">
            <expiration lifespan="3600000"/>
        </distributed-cache>

        <!--
          Cache action tokens used for user actions
          Example: password reset, email verification
        -->
        <distributed-cache name="actionTokens" owners="3">
            <expiration lifespan="3600000"/>
        </distributed-cache>

    </cache-container>

</infinispan>